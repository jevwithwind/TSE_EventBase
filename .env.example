# TSE_EventBase Environment Variables

# EDINET API Key - Required only if using EDINET scraper (edinet_scraper.py)
# for fetching formal regulatory filings (securities reports, large holding reports, etc.)
# Not needed if using TDnet (Yanoshin) only.
# Register at https://disclosure.edinet-fsa.go.jp/
EDINET_API_KEY=your_edinet_api_key_here

# --- AI Classification (Optional) ---
# The following keys are only required if running run_ai_classify.py.
# Leave blank or omit entirely if you are not using LLM-powered classification.
# The keyword-based classifier (run_categorize.py) works without any AI keys.

# OpenAI-compatible API Key
OPENAI_API_KEY=

# OpenAI-compatible Base URL - leave blank to use OpenAI's standard endpoint,
# or set to any OpenAI-compatible service (e.g. Azure OpenAI, local Ollama, Qwen, etc.)
OPENAI_BASE_URL=

# Model name to use for classification (e.g. gpt-4o, qwen3.5-plus, llama3)
MODEL=gpt-4o
