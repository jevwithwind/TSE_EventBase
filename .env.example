# TSE_EventBase Environment Variables

# EDINET API Key - Required for accessing EDINET filings
# Register at https://disclosure.edinet-fsa.go.jp/
EDINET_API_KEY=your_edinet_api_key_here

# Anthropic API Key - Required for AI event classification
# Can be a standard Anthropic API key or a key for any Anthropic-compatible service
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic Base URL - Optional custom endpoint for Anthropic-compatible services
# Leave empty to use standard Anthropic API, or specify custom endpoint
ANTHROPIC_BASE_URL=your_anthropic_base_url_here
